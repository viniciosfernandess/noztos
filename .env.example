# ─────────────────────────────────────────────────────────────────────
# noztos — environment variables for self-hosted setup
# ─────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────

# Postgres database. Easiest path: free Supabase project (supabase.com).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/noztos"

# Direct (non-pooled) URL — used by Prisma migrate. For Supabase, this
# is the connection string with the same credentials on port 5432
# without the pooler hostname (or :5432 with port 5432 instead of 6543).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/noztos"

# Secret used to sign session cookies + encrypt OAuth tokens at rest.
# Generate a strong value:  openssl rand -hex 32
NODE_SECRET="change-me-to-a-strong-random-string"

# ── GitHub OAuth (optional but recommended) ──────────────────────────
# Lets the app clone/push to your GitHub repos. Create an OAuth app
# at https://github.com/settings/developers — callback URL:
# http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/api/auth/github/callback"

# ── Admin operator console (optional) ────────────────────────────────
# Credentials for /admin/login. Lets you peek at signups + activity.
# Self-hosted single-user — set both, or leave blank to disable.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# Set to your user id (from the users table) once you've signed up
# locally to grant yourself admin access in the UI.
ADMIN_USER_IDS=""

# ── Resend (optional — password reset email) ─────────────────────────
# Get a key at https://resend.com — only needed if you want the
# "forgot password" flow to send emails. Without it, the flow silently
# no-ops (user can still reset via DB).
RESEND_API_KEY=""

# ── Voyage AI (optional — semantic code search) ──────────────────────
# Powers the /search endpoint. Without it, search falls back to grep.
# Get a key at https://dash.voyageai.com
VOYAGE_API_KEY=""

# ── Slack (optional — workflow notifications) ────────────────────────
# Lets the workflow runner ping a Slack channel when a step starts /
# finishes. Create an app at https://api.slack.com/apps with
# chat:write + channels:read scope.
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:3000/api/auth/slack/callback"
