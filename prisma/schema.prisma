generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  name           String
  company        String?
  role           String?
  avatarUrl      String?
  anthropicToken String?
  slackToken     String?
  emailVerified  Boolean       @default(false)
  createdAt      DateTime      @default(now())
  lastActive     DateTime      @updatedAt
  githubToken    String?
  chatMessages      ChatMessage[]
  projects          Project[]
  tasks             Task[]
  companionTokens   CompanionToken[]

  @@map("users")
}

model CompanionToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  name        String   @default("Default")
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([token])
  @@index([userId])
  @@map("companion_tokens")
}

// Singleton row holding the system-prompt config every companion daemon
// fetches at startup and refreshes via SSE push. Lives in the DB instead
// of the daemon's source bundle so prompt iteration can ship without
// asking users to update the local CLI. The companion mirrors this row
// into RAM and uses it for every `claude` spawn (zero per-spawn
// overhead). A bundled fallback in the daemon protects first-startup-
// offline scenarios; the row in this table is always the source of truth
// once reachable.
//
// Edited via SQL or admin UI; bumping `version` is what triggers the
// SSE 'config_updated' broadcast that pushes new prompts to every
// online companion in <1s.
model CompanionConfig {
  id               String   @id @default("singleton")
  // JSON: { plan: "...", ask: "...", agent: "..." }
  modePrompts      Json
  // Naming-rule appended to every mode prompt
  namingRule       String
  // JSON: { plan: ["AskUserQuestion"], ask: ["Edit","Write",...], agent: [] }
  disallowedTools  Json
  // Bumped on every change; companion uses this for cheap version checks
  version          String
  updatedAt        DateTime @updatedAt

  @@map("companion_config")
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  name           String
  repositoryPath String?
  slackChannel   String?
  slackWebhook   String?
  // Soft delete — user DELETE sets deletedAt (and status='deleted') so the
  // project disappears from the user's UI but every child (worktrees,
  // chats, messages) stays in the DB for ML training + audit. Hard
  // cascade via Prisma onDelete: Cascade only fires if an admin runs raw
  // SQL on the row, which isn't part of any user-facing flow.
  status         String          @default("open") // open | deleted
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  lastActivityAt DateTime?
  queueStatus    String          @default("paused")
  buildSessions  BuildSession[]
  chatMessages   ChatMessage[]
  chatSessions   ChatSession[]
  worktrees      Worktree[]
  collaborators  Collaborator[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository     Repository?
  resourceUsage  ResourceUsage[]
  slackLogs      SlackLog[]
  tasks          Task[]
  teamRuns       TeamRun[]
  teams          Team[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("projects")
}

model Repository {
  id               String     @id @default(cuid())
  projectId        String     @unique
  githubOwner      String
  githubRepo       String
  githubBranch     String     @default("main")
  lastSyncedSha    String?
  lastSyncedAt     DateTime?
  createdAt        DateTime   @default(now())
  lockedAt         DateTime?
  lockedBy         String?
  lockedByTaskId   String?
  sandboxId        String?
  sandboxStartedAt DateTime?
  sandboxStatus    String?
  fileTree         String?
  fileTreeUpdatedAt DateTime?
  // Project-level run script (e.g. "PORT=$BORNASTAR_PORT npm run dev").
  // When set, the user can start the dev server for any chat with one click.
  runScript        String?
  files            RepoFile[]
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("repositories")
}

model RepoFile {
  id              String     @id @default(cuid())
  repositoryId    String
  path            String
  content         String
  originalContent String
  isModified      Boolean    @default(false)
  isBinary        Boolean    @default(false)
  sizeBytes       Int        @default(0)
  blobSha         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@index([repositoryId, isModified])
  @@map("repo_files")
}

model Collaborator {
  id                String         @id @default(cuid())
  projectId         String?
  name              String
  description       String
  skillMd           String         @default("")
  isPlatformDefault Boolean        @default(false)
  phase             Phase
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  project           Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskSkillLogs     TaskSkillLog[]

  @@unique([name, projectId])
  @@index([projectId, isActive])
  @@map("collaborators")
}

model Team {
  id                        String   @id @default(cuid())
  projectId                 String
  name                      String
  collaboratorOrder         Json     @default("[]")
  hasBuilder                Boolean  @default(false)
  builderPosition           Int?
  rejectionRules            Json     @default("{}")
  restartFromCollaboratorId String?
  createdAt                 DateTime @default(now())
  tasks                     Task[]
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("teams")
}

// A Worktree is an isolated git branch + working directory inside the project's
// sandbox. Multiple chat sessions can live inside the same worktree, sharing
// the working files (just like multiple chats on main share the project root).
//
// When worktreeId on a ChatSession is null, the chat operates directly on
// the project's main directory (no isolation — the "Cursor local mode").
model Worktree {
  id           String        @id @default(cuid())
  projectId    String
  userId       String
  name         String        @default("New Worktree")
  status       String        @default("open") // open, archived, deleted, merged
  branchName   String
  worktreePath String
  baseCommit   String
  portBase     Int?
  // PR composition fields — the user (or agent) can type into these any
  // time on the Checks panel. They sit here so a draft survives across
  // chat sessions within the worktree and can pre-populate a real PR when
  // created. Null until someone starts writing.
  prTitleDraft String?
  prBodyDraft  String?
  // Stamped alongside status='deleted' so every layer (status-based or
  // timestamp-based) agrees on the unlinked state. Preserves the audit
  // trail — the row never leaves the DB.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     ChatSession[]
  todos        Todo[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([deletedAt])
  @@map("worktrees")
}

// Semantic-search index — chunks with voyage-code-2 embeddings. Declared
// here only so `prisma db push` sees the table exists and doesn't try to
// drop it; all reads / writes happen via raw SQL in
// lib/embeddings/{indexer,retriever} (the `embedding` column is pgvector
// and the HNSW index on it aren't fully representable in Prisma schema).
// `@@ignore` keeps this model out of the generated Prisma Client so no
// code path can accidentally query it with the ORM.
model RepoChunk {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repositoryId String
  filePath     String
  chunkType    String
  chunkName    String?
  content      String
  lineStart    Int?
  lineEnd      Int?
  embedding    Unsupported("vector(1536)")?
  lastModified DateTime? @default(now())
  touchCount   Int?      @default(0)

  @@unique([repositoryId, filePath, chunkName])
  @@index([repositoryId, lastModified(sort: Desc)], map: "repo_chunks_repo_idx")
  @@map("repo_chunks")
  @@ignore
}

// File-level import graph — same contract as RepoChunk: declared only to
// prevent drops, manipulated via raw SQL only.
model RepoImport {
  repositoryId String
  filePath     String
  importsPath  String

  @@id([repositoryId, filePath, importsPath])
  @@index([repositoryId, filePath], map: "repo_imports_file_idx")
  @@map("repo_imports")
  @@ignore
}

// Per-worktree checklist. Lives alongside git state in the Checks panel and
// lets the user (or agent) track intentions / follow-ups for the branch.
// For main-chat todos we attach to a session instead of a worktree, via
// the nullable sessionId — exactly one of worktreeId / sessionId is set.
model Todo {
  id          String       @id @default(cuid())
  worktreeId  String?
  sessionId   String?
  content     String
  done        Boolean      @default(false)
  // Sort order so drag-to-reorder and stable lists work without depending
  // on createdAt alone. New items land at the end (max+1).
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  worktree    Worktree?    @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  session     ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([worktreeId])
  @@index([sessionId])
  @@map("todos")
}

model ChatSession {
  id             String         @id @default(cuid())
  projectId      String
  userId         String
  name           String         @default("New Chat")
  status         String         @default("open")
  permissionMode PermissionMode @default(auto)
  // worktreeId — when null, this chat lives on main (the project root).
  // When set, the chat lives inside the parent Worktree (its branch + dir).
  worktreeId     String?
  // Files this chat has touched (write/edit/delete tool calls). Used to
  // attribute diff stats per chat on main, where multiple chats share the
  // same working tree. Always relative paths from the project root.
  touchedPaths   String[]       @default([])
  // Soft delete — user-facing DELETE sets this timestamp instead of
  // dropping the row. Authoritative audit log of conversations is
  // preserved (important for training + compliance). Hard delete only
  // happens through explicit admin/retention tooling.
  deletedAt      DateTime?

  // ── Claude Code state ─────────────────────────────────────────────────
  // Latest Claude Code --resume id. Persisted so a browser refresh (or
  // switching devices) can pick the same Claude conversation back up
  // instead of starting a fresh one and losing context.
  claudeSessionId String?
  // Rollup metrics — updated as messages land. Lets the sidebar list
  // cost/usage per chat without aggregating messages on every render.
  totalCostUsd   Float          @default(0)
  totalTokens    Int            @default(0)
  numTurns       Int            @default(0)
  lastMessageAt  DateTime?
  // Unread marker — stamps every time the user views this chat. A
  // message (role assistant/tool) created after this timestamp is
  // considered unread. Null = chat has never been opened yet.
  lastReadAt     DateTime?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  messages       ChatMessage[]
  todos          Todo[]
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worktree       Worktree?      @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([worktreeId])
  @@index([userId, lastMessageAt])
  @@map("chat_sessions")
}

// A single persisted event from a Claude Code conversation. One row per
// logical turn piece (user prompt, assistant text, tool call, tool result,
// final result). All columns populated where the stream-json event
// provides them, keeping the table rich enough to serve as our future
// training dataset without back-filling gymnastics later.
model ChatMessage {
  id              String       @id @default(cuid())
  sessionId       String
  projectId       String
  userId          String
  // Denormalized worktree the chat was attached to at the moment of this
  // message — lets us answer "what was Claude looking at?" without joining
  // session → worktree every time. Null ⇒ main.
  worktreeId      String?

  // Discriminator. What kind of event this row represents.
  //   user      — prompt sent by the human
  //   assistant — Claude's text reply
  //   tool      — a single tool use (before + result, updated in place)
  //   system    — errors and other out-of-band messages
  role            String

  // Primary text payload. For tools this is the human-readable label
  // (e.g. "Reading ~/file.ts"); structured data lives in toolInput / toolResult.
  content         String

  // ── Tool call structure (when role = 'tool') ──────────────────────────
  toolName        String?
  toolInput       Json?
  toolResult      Json?
  toolUseId       String?
  toolError       Boolean      @default(false)

  // ── Conversation graph ────────────────────────────────────────────────
  // The message that caused this one to exist. For tool results, this
  // points at the assistant tool_use that triggered the run; for
  // regenerations, at the prior assistant reply the user rejected.
  parentMessageId String?
  // When the user edits + resends a previous prompt, the new row points
  // back so we can reconstruct the edit history.
  editOfMessageId String?
  // User hit Stop mid-stream, cutting the reply short. Signals "Claude
  // didn't finish" for training filters.
  wasInterrupted  Boolean      @default(false)
  // User asked Claude to try again — the prior message (parentMessageId)
  // was rejected. Strong preference signal.
  wasRegenerated  Boolean      @default(false)
  // Flipped by the server when a turn's claudeSessionId differs from the
  // prior turn's — signals Claude auto-compacted the conversation. Lets
  // us filter compaction boundaries out of training data (the pre-compact
  // context was dropped, so continuity is partially broken).
  wasCompacted    Boolean      @default(false)
  // Soft delete — same rationale as ChatSession.deletedAt.
  deletedAt       DateTime?

  // ── Per-turn metrics (from the final 'result' event) ──────────────────
  costUsd           Float?
  durationMs        Int?
  inputTokens       Int?
  outputTokens      Int?
  cacheReadTokens   Int?
  cacheCreateTokens Int?

  // ── Context snapshot at time of message ───────────────────────────────
  // Stored so we can compare behavior across models / modes without
  // reconstructing state from timestamps.
  model           String?
  permissionMode  String?
  claudeSessionId String?

  // ── Legacy columns from the old chat engine. Kept while the legacy
  // Task/Team pipeline still renders them; dropped once we retire that
  // system. New rows written by the Claude Code flow leave them null.
  sender          String?
  mode            String       @default("no_skill")

  createdAt       DateTime     @default(now())

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session         ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([worktreeId, createdAt])
  @@index([toolUseId])
  @@index([role, createdAt])
  @@map("chat_messages")
}

model Task {
  id                  String           @id @default(cuid())
  projectId           String
  userId              String
  name                String
  instruction         String?
  context             Json             @default("{}")
  accumulatedContext  Json             @default("{}")
  canModifyRepo       Boolean          @default(false)
  permissionMode      PermissionMode   @default(edit)
  executorType        ExecutorType     @default(no_skill)
  executorId          String?
  status              TaskStatus       @default(pending)
  isRecurring         Boolean          @default(false)
  recurrenceConfig    Json?
  scheduledAt         DateTime?
  pausedAt            DateTime?
  pausedAtIteration   Int?
  pausedAtEmployee    String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  queuePosition       Int?
  originalScheduledAt DateTime?
  rescheduledCount    Int              @default(0)
  rescheduledReason   String?
  resourceUsage       ResourceUsage[]
  slackLogs           SlackLog[]
  buildLogs           TaskBuildLog[]
  iterations          TaskIteration[]
  skillLogs           TaskSkillLog[]
  suggestions         TaskSuggestion[]
  team                Team?            @relation(fields: [executorId], references: [id])
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("tasks")
}

model TaskIteration {
  id                       String         @id @default(cuid())
  taskId                   String
  iterationNumber          Int
  rejectionReason          String?
  rejectedByCollaboratorId String?
  createdAt                DateTime       @default(now())
  buildLogs                TaskBuildLog[]
  task                     Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skillLogs                TaskSkillLog[]

  @@index([taskId])
  @@map("task_iterations")
}

model TaskSkillLog {
  id               String         @id @default(cuid())
  taskId           String
  iterationId      String?
  collaboratorId   String?
  collaboratorName String
  inputReceived    String?
  thoughts         String?
  conclusion       String?
  passedForward    String?
  approved         Boolean?
  rejectionReason  String?
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  collaborator     Collaborator?  @relation(fields: [collaboratorId], references: [id])
  iteration        TaskIteration? @relation(fields: [iterationId], references: [id])
  task             Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_skill_logs")
}

model TaskBuildLog {
  id                 String         @id @default(cuid())
  taskId             String
  iterationId        String?
  filesTouched       Json           @default("[]")
  linesAdded         Int            @default(0)
  linesRemoved       Int            @default(0)
  technicalDecisions String?
  rawLog             String?
  createdAt          DateTime       @default(now())
  iteration          TaskIteration? @relation(fields: [iterationId], references: [id])
  task               Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_build_logs")
}

model TaskSuggestion {
  id              String   @id @default(cuid())
  taskId          String
  suggestionText  String
  reason          String?
  accepted        Boolean  @default(false)
  generatedTaskId String?
  createdAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_suggestions")
}

model SlackLog {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  messageSent String
  channel     String
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id])

  @@index([projectId, delivered])
  @@map("slack_logs")
}

model ResourceUsage {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  taskId     String?
  cpuSeconds Float    @default(0)
  gpuSeconds Float    @default(0)
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([userId, projectId])
  @@map("resource_usage")
}

model TeamRun {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  teamConfigJson Json
  userMessage    String
  status         String   @default("running")
  plan           Json     @default("{}")
  state          Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("team_runs")
}

model BuildSession {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  buildWith String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, active])
  @@map("build_sessions")
}

enum Phase {
  planner
  reviewer
}

enum TaskStatus {
  pending
  queue
  progress
  completed
  done
}

enum ExecutorType {
  no_skill
  skill
  team
}

enum PermissionMode {
  plan
  edit
  auto
  agent
}
