generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  name           String
  company        String?
  role           String?
  avatarUrl      String?
  anthropicToken String?
  slackToken     String?
  emailVerified  Boolean       @default(false)
  createdAt      DateTime      @default(now())
  lastActive     DateTime      @updatedAt
  githubToken    String?
  chatMessages   ChatMessage[]
  projects       Project[]
  tasks          Task[]

  @@map("users")
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  name           String
  repositoryPath String?
  slackChannel   String?
  slackWebhook   String?
  createdAt      DateTime        @default(now())
  lastActivityAt DateTime?
  queueStatus    String          @default("paused")
  buildSessions  BuildSession[]
  chatMessages   ChatMessage[]
  chatSessions   ChatSession[]
  worktrees      Worktree[]
  collaborators  Collaborator[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository     Repository?
  resourceUsage  ResourceUsage[]
  slackLogs      SlackLog[]
  tasks          Task[]
  teamRuns       TeamRun[]
  teams          Team[]

  @@index([userId])
  @@map("projects")
}

model Repository {
  id               String     @id @default(cuid())
  projectId        String     @unique
  githubOwner      String
  githubRepo       String
  githubBranch     String     @default("main")
  lastSyncedSha    String?
  lastSyncedAt     DateTime?
  createdAt        DateTime   @default(now())
  lockedAt         DateTime?
  lockedBy         String?
  lockedByTaskId   String?
  sandboxId        String?
  sandboxStartedAt DateTime?
  sandboxStatus    String?
  fileTree         String?
  fileTreeUpdatedAt DateTime?
  // Project-level run script (e.g. "PORT=$BORNASTAR_PORT npm run dev").
  // When set, the user can start the dev server for any chat with one click.
  runScript        String?
  files            RepoFile[]
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("repositories")
}

model RepoFile {
  id              String     @id @default(cuid())
  repositoryId    String
  path            String
  content         String
  originalContent String
  isModified      Boolean    @default(false)
  isBinary        Boolean    @default(false)
  sizeBytes       Int        @default(0)
  blobSha         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@index([repositoryId, isModified])
  @@map("repo_files")
}

model Collaborator {
  id                String         @id @default(cuid())
  projectId         String?
  name              String
  description       String
  skillMd           String         @default("")
  isPlatformDefault Boolean        @default(false)
  phase             Phase
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  project           Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskSkillLogs     TaskSkillLog[]

  @@unique([name, projectId])
  @@index([projectId, isActive])
  @@map("collaborators")
}

model Team {
  id                        String   @id @default(cuid())
  projectId                 String
  name                      String
  collaboratorOrder         Json     @default("[]")
  hasBuilder                Boolean  @default(false)
  builderPosition           Int?
  rejectionRules            Json     @default("{}")
  restartFromCollaboratorId String?
  createdAt                 DateTime @default(now())
  tasks                     Task[]
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("teams")
}

// A Worktree is an isolated git branch + working directory inside the project's
// sandbox. Multiple chat sessions can live inside the same worktree, sharing
// the working files (just like multiple chats on main share the project root).
//
// When worktreeId on a ChatSession is null, the chat operates directly on
// the project's main directory (no isolation — the "Cursor local mode").
model Worktree {
  id           String        @id @default(cuid())
  projectId    String
  userId       String
  name         String        @default("New Worktree")
  status       String        @default("open") // open, archived, trashed, deleted, merged
  branchName   String
  worktreePath String
  baseCommit   String
  portBase     Int?
  trashedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     ChatSession[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("worktrees")
}

model ChatSession {
  id             String         @id @default(cuid())
  projectId      String
  userId         String
  name           String         @default("New Chat")
  status         String         @default("open")
  permissionMode PermissionMode @default(leitura)
  // worktreeId — when null, this chat lives on main (the project root).
  // When set, the chat lives inside the parent Worktree (its branch + dir).
  worktreeId     String?
  // Files this chat has touched (write/edit/delete tool calls). Used to
  // attribute diff stats per chat on main, where multiple chats share the
  // same working tree. Always relative paths from the project root.
  touchedPaths   String[]       @default([])
  // Lifecycle helper for the trash flow
  trashedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  messages       ChatMessage[]
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worktree       Worktree?      @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([worktreeId])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String       @id @default(cuid())
  projectId     String
  userId        String
  content       String
  sender        String
  activeSkillId String?
  mode          String       @default("no_skill")
  createdAt     DateTime     @default(now())
  sessionId     String?
  report        Json?
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session       ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([projectId, createdAt])
  @@map("chat_messages")
}

model Task {
  id                  String           @id @default(cuid())
  projectId           String
  userId              String
  name                String
  instruction         String?
  context             Json             @default("{}")
  accumulatedContext  Json             @default("{}")
  canModifyRepo       Boolean          @default(false)
  permissionMode      PermissionMode   @default(edicao)
  executorType        ExecutorType     @default(no_skill)
  executorId          String?
  status              TaskStatus       @default(pending)
  isRecurring         Boolean          @default(false)
  recurrenceConfig    Json?
  scheduledAt         DateTime?
  pausedAt            DateTime?
  pausedAtIteration   Int?
  pausedAtEmployee    String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  queuePosition       Int?
  originalScheduledAt DateTime?
  rescheduledCount    Int              @default(0)
  rescheduledReason   String?
  resourceUsage       ResourceUsage[]
  slackLogs           SlackLog[]
  buildLogs           TaskBuildLog[]
  iterations          TaskIteration[]
  skillLogs           TaskSkillLog[]
  suggestions         TaskSuggestion[]
  team                Team?            @relation(fields: [executorId], references: [id])
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("tasks")
}

model TaskIteration {
  id                       String         @id @default(cuid())
  taskId                   String
  iterationNumber          Int
  rejectionReason          String?
  rejectedByCollaboratorId String?
  createdAt                DateTime       @default(now())
  buildLogs                TaskBuildLog[]
  task                     Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skillLogs                TaskSkillLog[]

  @@index([taskId])
  @@map("task_iterations")
}

model TaskSkillLog {
  id               String         @id @default(cuid())
  taskId           String
  iterationId      String?
  collaboratorId   String?
  collaboratorName String
  inputReceived    String?
  thoughts         String?
  conclusion       String?
  passedForward    String?
  approved         Boolean?
  rejectionReason  String?
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  collaborator     Collaborator?  @relation(fields: [collaboratorId], references: [id])
  iteration        TaskIteration? @relation(fields: [iterationId], references: [id])
  task             Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_skill_logs")
}

model TaskBuildLog {
  id                 String         @id @default(cuid())
  taskId             String
  iterationId        String?
  filesTouched       Json           @default("[]")
  linesAdded         Int            @default(0)
  linesRemoved       Int            @default(0)
  technicalDecisions String?
  rawLog             String?
  createdAt          DateTime       @default(now())
  iteration          TaskIteration? @relation(fields: [iterationId], references: [id])
  task               Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_build_logs")
}

model TaskSuggestion {
  id              String   @id @default(cuid())
  taskId          String
  suggestionText  String
  reason          String?
  accepted        Boolean  @default(false)
  generatedTaskId String?
  createdAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_suggestions")
}

model SlackLog {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  messageSent String
  channel     String
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id])

  @@index([projectId, delivered])
  @@map("slack_logs")
}

model ResourceUsage {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  taskId     String?
  cpuSeconds Float    @default(0)
  gpuSeconds Float    @default(0)
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([userId, projectId])
  @@map("resource_usage")
}

model TeamRun {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  teamConfigJson Json
  userMessage    String
  status         String   @default("running")
  plan           Json     @default("{}")
  state          Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("team_runs")
}

model BuildSession {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  buildWith String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, active])
  @@map("build_sessions")
}

enum Phase {
  planner
  reviewer
}

enum TaskStatus {
  pending
  queue
  progress
  completed
  done
}

enum ExecutorType {
  no_skill
  skill
  team
}

enum PermissionMode {
  leitura
  planejamento
  edicao
}
