generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  name            String
  company         String?
  role            String?
  avatarUrl       String?
  anthropicToken  String?
  slackToken      String?
  emailVerified   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  lastActive      DateTime         @updatedAt
  githubToken     String?
  chatMessages    ChatMessage[]
  projects        Project[]
  tasks           Task[]
  companionTokens CompanionToken[]
  // Cloud Mirror back-references (see ARCHITECTURE.md "Cloud Mirror").
  // These don't add columns to the users table — Prisma resolves them
  // from the child models' FKs. Safe additive change.
  encryptionKey   UserEncryptionKey?
  gitObjects      GitObject[]
  sandboxSessions SandboxSession[]
  passwordResetTokens PasswordResetToken[]
  // MVP gate for cloud activation. Pre-billing, this boolean controls
  // whether the "Continuar na nuvem" button is visible/active. Post-
  // billing this becomes a credit/plan check.
  cloudEnabled    Boolean          @default(false)

  @@map("users")
}

model CompanionToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String    @unique
  name       String    @default("Default")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@index([token])
  @@index([userId])
  @@map("companion_tokens")
}

// Singleton row holding the system-prompt config every companion daemon
// fetches at startup and refreshes via SSE push. Lives in the DB instead
// of the daemon's source bundle so prompt iteration can ship without
// asking users to update the local CLI. The companion mirrors this row
// into RAM and uses it for every `claude` spawn (zero per-spawn
// overhead). A bundled fallback in the daemon protects first-startup-
// offline scenarios; the row in this table is always the source of truth
// once reachable.
//
// Edited via SQL or admin UI; bumping `version` is what triggers the
// SSE 'config_updated' broadcast that pushes new prompts to every
// online companion in <1s.
model CompanionConfig {
  id              String   @id @default("singleton")
  // JSON: { plan: "...", ask: "...", agent: "..." }
  modePrompts     Json
  // Naming-rule appended to every mode prompt
  namingRule      String
  // JSON: { plan: ["AskUserQuestion"], ask: ["Edit","Write",...], agent: [] }
  disallowedTools Json
  // Bumped on every change; companion uses this for cheap version checks
  version         String
  updatedAt       DateTime @updatedAt

  @@map("companion_config")
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  name           String
  repositoryPath String?
  slackChannel   String?
  slackWebhook   String?
  // Soft delete — user DELETE sets deletedAt (and status='deleted') so the
  // project disappears from the user's UI but every child (worktrees,
  // chats, messages) stays in the DB for ML training + audit. Hard
  // cascade via Prisma onDelete: Cascade only fires if an admin runs raw
  // SQL on the row, which isn't part of any user-facing flow.
  status         String          @default("open") // open | deleted
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  lastActivityAt DateTime?
  queueStatus    String          @default("paused")
  buildSessions  BuildSession[]
  chatMessages   ChatMessage[]
  chatSessions   ChatSession[]
  worktrees      Worktree[]
  collaborators  Collaborator[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository     Repository?
  resourceUsage  ResourceUsage[]
  slackLogs      SlackLog[]
  tasks          Task[]
  teamRuns       TeamRun[]
  teams          Team[]
  workflowRuns   WorkflowRun[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("projects")
}

model Repository {
  id                String     @id @default(cuid())
  projectId         String     @unique
  githubOwner       String
  githubRepo        String
  githubBranch      String     @default("main")
  lastSyncedSha     String?
  lastSyncedAt      DateTime?
  createdAt         DateTime   @default(now())
  lockedAt          DateTime?
  lockedBy          String?
  lockedByTaskId    String?
  sandboxId         String?
  sandboxStartedAt  DateTime?
  sandboxStatus     String?
  fileTree          String?
  fileTreeUpdatedAt DateTime?
  // Project-level run script (e.g. "PORT=$BORNASTAR_PORT npm run dev").
  // When set, the user can start the dev server for any chat with one click.
  runScript         String?
  files             RepoFile[]
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("repositories")
}

model RepoFile {
  id              String     @id @default(cuid())
  repositoryId    String
  path            String
  content         String
  originalContent String
  isModified      Boolean    @default(false)
  isBinary        Boolean    @default(false)
  sizeBytes       Int        @default(0)
  blobSha         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@index([repositoryId, isModified])
  @@map("repo_files")
}

model Collaborator {
  id                String   @id @default(cuid())
  projectId         String?
  name              String
  description       String
  skillMd           String   @default("")
  isPlatformDefault Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  project           Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([name, projectId])
  @@index([projectId, isActive])
  @@map("collaborators")
}

model Team {
  id                        String   @id @default(cuid())
  projectId                 String
  name                      String
  collaboratorOrder         Json     @default("[]")
  hasBuilder                Boolean  @default(false)
  builderPosition           Int?
  rejectionRules            Json     @default("{}")
  restartFromCollaboratorId String?
  createdAt                 DateTime @default(now())
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("teams")
}

// A Worktree is an isolated git branch + working directory inside the project's
// sandbox. Multiple chat sessions can live inside the same worktree, sharing
// the working files (just like multiple chats on main share the project root).
//
// When worktreeId on a ChatSession is null, the chat operates directly on
// the project's main directory (no isolation — the "Cursor local mode").
model Worktree {
  id           String        @id @default(cuid())
  projectId    String
  userId       String
  name         String        @default("New Worktree")
  status       String        @default("open") // open, archived, deleted, merged
  branchName   String
  worktreePath String
  baseCommit   String
  portBase     Int?
  // PR composition fields — the user (or agent) can type into these any
  // time on the Checks panel. They sit here so a draft survives across
  // chat sessions within the worktree and can pre-populate a real PR when
  // created. Null until someone starts writing.
  prTitleDraft String?
  prBodyDraft  String?
  // Stamped alongside status='deleted' so every layer (status-based or
  // timestamp-based) agrees on the unlinked state. Preserves the audit
  // trail — the row never leaves the DB.
  deletedAt    DateTime?
  // Soft "trash" state (status='trashed') — distinct from deletedAt
  // so users can recover within a grace window before permanent
  // removal. Set when the user puts a worktree in the trash; cleared
  // on restore; promoted to deletedAt on permanent delete.
  trashedAt    DateTime?
  // Paths touched by Task iterations since the last commit on this
  // worktree. Drives the "T" badge in the Changes list, paired with
  // the "U" (uncommitted) badge. Each completed iteration merges its
  // filesTouched in; the commit endpoint clears the array. We store
  // raw paths (Json string[]) — cheap to read, set semantics handled
  // at the merge call site.
  taskTouchedPaths Json     @default("[]")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     ChatSession[]
  todos        Todo[]
  tasks        Task[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Cloud Mirror back-references (see ARCHITECTURE.md "Cloud Mirror").
  // Inverse-only — no columns added to worktrees table.
  mirror           WorktreeMirror?
  fileEntries      WorktreeFileEntry[]
  unpushedCommits  UnpushedCommit[]
  sandboxSessions  SandboxSession[]
  // Cloud Mirror — 'local' or 'cloud'. Persists across browser sessions
  // so a user who switched a worktree to cloud and then closed the tab
  // returns to find it still in cloud mode (re-provision sandbox if the
  // E2B instance was GC'd in the meantime). UI badge reads this; routing
  // logic in compute.ts reads this; bridge.mjs scopes itself by this.
  activeContext    String   @default("local")

  @@index([projectId, status])
  @@index([deletedAt])
  @@map("worktrees")
}

// Semantic-search index — chunks with voyage-code-2 embeddings. Declared
// here only so `prisma db push` sees the table exists and doesn't try to
// drop it; all reads / writes happen via raw SQL in
// lib/embeddings/{indexer,retriever} (the `embedding` column is pgvector
// and the HNSW index on it aren't fully representable in Prisma schema).
// `@@ignore` keeps this model out of the generated Prisma Client so no
// code path can accidentally query it with the ORM.
model RepoChunk {
  id           String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repositoryId String
  filePath     String
  chunkType    String
  chunkName    String?
  content      String
  lineStart    Int?
  lineEnd      Int?
  embedding    Unsupported("vector(1536)")?
  lastModified DateTime?                    @default(now())
  touchCount   Int?                         @default(0)

  @@unique([repositoryId, filePath, chunkName])
  @@index([repositoryId, lastModified(sort: Desc)], map: "repo_chunks_repo_idx")
  @@map("repo_chunks")
  @@ignore
}

// File-level import graph — same contract as RepoChunk: declared only to
// prevent drops, manipulated via raw SQL only.
model RepoImport {
  repositoryId String
  filePath     String
  importsPath  String

  @@id([repositoryId, filePath, importsPath])
  @@index([repositoryId, filePath], map: "repo_imports_file_idx")
  @@map("repo_imports")
  @@ignore
}

// Per-worktree checklist. Lives alongside git state in the Checks panel and
// lets the user (or agent) track intentions / follow-ups for the branch.
// For main-chat todos we attach to a session instead of a worktree, via
// the nullable sessionId — exactly one of worktreeId / sessionId is set.
model Todo {
  id         String       @id @default(cuid())
  worktreeId String?
  sessionId  String?
  content    String
  done       Boolean      @default(false)
  // Sort order so drag-to-reorder and stable lists work without depending
  // on createdAt alone. New items land at the end (max+1).
  position   Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  worktree   Worktree?    @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  session    ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([worktreeId])
  @@index([sessionId])
  @@map("todos")
}

model ChatSession {
  id             String         @id @default(cuid())
  projectId      String
  userId         String
  name           String         @default("New Chat")
  status         String         @default("open")
  permissionMode PermissionMode @default(auto)
  // worktreeId — when null, this chat lives on main (the project root).
  // When set, the chat lives inside the parent Worktree (its branch + dir).
  worktreeId     String?
  // Files this chat has touched (write/edit/delete tool calls). Used to
  // attribute diff stats per chat on main, where multiple chats share the
  // same working tree. Always relative paths from the project root.
  touchedPaths   String[]       @default([])
  // Soft delete — user-facing DELETE sets this timestamp instead of
  // dropping the row. Authoritative audit log of conversations is
  // preserved (important for training + compliance). Hard delete only
  // happens through explicit admin/retention tooling.
  deletedAt      DateTime?
  // Trash bucket — set when the user puts a chat in the trash via
  // the worktree's "trash" action. Distinct from deletedAt so a chat
  // can be restored within the grace window before permanent removal.
  trashedAt      DateTime?

  // ── Claude Code state ─────────────────────────────────────────────────
  // Latest Claude Code --resume id. Persisted so a browser refresh (or
  // switching devices) can pick the same Claude conversation back up
  // instead of starting a fresh one and losing context.
  claudeSessionId String?
  // Rollup metrics — updated as messages land. Lets the sidebar list
  // cost/usage per chat without aggregating messages on every render.
  totalCostUsd    Float     @default(0)
  totalTokens     Int       @default(0)
  numTurns        Int       @default(0)
  lastMessageAt   DateTime?
  // Unread marker — stamps every time the user views this chat. A
  // message (role assistant/tool) created after this timestamp is
  // considered unread. Null = chat has never been opened yet.
  lastReadAt      DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
  todos        Todo[]
  workflowRuns WorkflowRun[]
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worktree     Worktree?     @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([worktreeId])
  @@index([userId, lastMessageAt])
  @@map("chat_sessions")
}

// A single persisted event from a Claude Code conversation. One row per
// logical turn piece (user prompt, assistant text, tool call, tool result,
// final result). All columns populated where the stream-json event
// provides them, keeping the table rich enough to serve as our future
// training dataset without back-filling gymnastics later.
model ChatMessage {
  id         String  @id @default(cuid())
  sessionId  String
  projectId  String
  userId     String
  // Denormalized worktree the chat was attached to at the moment of this
  // message — lets us answer "what was Claude looking at?" without joining
  // session → worktree every time. Null ⇒ main.
  worktreeId String?

  // Discriminator. What kind of event this row represents.
  //   user      — prompt sent by the human
  //   assistant — Claude's text reply
  //   tool      — a single tool use (before + result, updated in place)
  //   system    — errors and other out-of-band messages
  role String

  // Primary text payload. For tools this is the human-readable label
  // (e.g. "Reading ~/file.ts"); structured data lives in toolInput / toolResult.
  content String

  // ── Tool call structure (when role = 'tool') ──────────────────────────
  toolName   String?
  toolInput  Json?
  toolResult Json?
  toolUseId  String?
  toolError  Boolean @default(false)

  // ── Conversation graph ────────────────────────────────────────────────
  // The message that caused this one to exist. For tool results, this
  // points at the assistant tool_use that triggered the run; for
  // regenerations, at the prior assistant reply the user rejected.
  parentMessageId String?
  // When the user edits + resends a previous prompt, the new row points
  // back so we can reconstruct the edit history.
  editOfMessageId String?
  // User hit Stop mid-stream, cutting the reply short. Signals "Claude
  // didn't finish" for training filters.
  wasInterrupted  Boolean   @default(false)
  // User asked Claude to try again — the prior message (parentMessageId)
  // was rejected. Strong preference signal.
  wasRegenerated  Boolean   @default(false)
  // Flipped by the server when a turn's claudeSessionId differs from the
  // prior turn's — signals Claude auto-compacted the conversation. Lets
  // us filter compaction boundaries out of training data (the pre-compact
  // context was dropped, so continuity is partially broken).
  wasCompacted    Boolean   @default(false)
  // Soft delete — same rationale as ChatSession.deletedAt.
  deletedAt       DateTime?

  // ── Per-turn metrics (from the final 'result' event) ──────────────────
  costUsd           Float?
  durationMs        Int?
  inputTokens       Int?
  outputTokens      Int?
  cacheReadTokens   Int?
  cacheCreateTokens Int?

  // ── Context snapshot at time of message ───────────────────────────────
  // Stored so we can compare behavior across models / modes without
  // reconstructing state from timestamps.
  model           String?
  permissionMode  String?
  claudeSessionId String?

  // ── Legacy columns from the old chat engine. Kept while the legacy
  // Task/Team pipeline still renders them; dropped once we retire that
  // system. New rows written by the Claude Code flow leave them null.
  sender String?
  mode   String  @default("no_skill")

  createdAt DateTime @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([worktreeId, createdAt])
  @@index([toolUseId])
  @@index([role, createdAt])
  @@map("chat_messages")
}

// A Task is a deferred work unit: a snapshot of chat context (frozen at
// creation time) plus an instruction + executor + chat mode the user
// configures and runs later. The execution targets the worktree the
// chat came from, so an "agent" task touches the same branch as if the
// user had typed the instruction inside the chat itself — just queued
// to run out-of-band. Re-running creates a new TaskIteration; the
// model's view of "history" is the frozen contextSnapshot + all prior
// iteration outputs, fed in order like a side-conversation.
model Task {
  id              String          @id @default(cuid())
  projectId       String
  worktreeId      String // branch binding — every task lives on a worktree
  userId          String
  name            String // editable, defaults to the source chat's name
  instruction     String? // current user prompt — null until the manage modal is filled
  // Frozen chat-history snapshot from clicked-message backwards, sized
  // the same way Bridge IN sizes context for a workflow. Never changes
  // after creation.
  contextSource   Json // { chatId, cutoffMessageId, cutoffAt }
  contextSnapshot String // chat XML, frozen at click time
  // Configuration set in the manage modal — null until configured
  executorKind    String? // 'workflow' | 'skill'
  executorId      String? // 'build' | 'debug' | 'ceo' | 'architect' | ... — no FK on purpose, string keys
  chatMode        String? // 'agent' | 'plan' | 'ask' (workflow → forced 'agent')
  status          TaskStatus      @default(pending)
  scheduledAt     DateTime? // set when user clicks Schedule
  // Done-review tracking. null = task finished but user hasn't opened
  // the result yet (card shows amber). Stamped on first open of the
  // manage modal in done/failed state. Reset to null on every new
  // iteration so re-runs require re-review.
  reviewedAt      DateTime?
  // When this task was forked from another (Create chained task), this
  // points to the source. Lets the chained-context builder traverse
  // back across the chain without re-querying.
  sourceTaskId    String?
  // Soft delete — DELETE requests + worktree-trash cascade flip this
  // instead of dropping the row. User stops seeing the task; the audit
  // trail (iterations, outputs, files touched) stays in the DB for
  // training / compliance / retro. Hard delete only happens via admin
  // retention tooling.
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  iterations      TaskIteration[]
  resourceUsage   ResourceUsage[]
  slackLogs       SlackLog[]
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  worktree        Worktree        @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([worktreeId])
  @@index([status, scheduledAt])
  @@map("tasks")
}

// One execution of a Task. Re-running the task = new iteration row.
// The model reading the task's history sees: contextSnapshot preamble
// + every iteration's instruction/outputSummary in order + the current
// instruction. Linkage to WorkflowRun lets workflow-kind executions
// reuse the audit trail we already keep on /build and /debug runs.
model TaskIteration {
  id              String    @id @default(cuid())
  taskId          String
  iterationNumber Int // 1-based; unique per task
  instruction     String // what the user asked this run
  executorKind    String // 'workflow' | 'skill'
  executorId      String
  chatMode        String // 'agent' | 'plan' | 'ask'
  status          String // 'queued' | 'running' | 'completed' | 'failed' | 'cancelled'
  startedAt       DateTime?
  finishedAt      DateTime?
  outputSummary   String? // short summary fed into next iteration's preamble
  fullOutput      String? // complete model output (for the Done modal)
  filesTouched    Json      @default("[]")
  errorReason     String?
  workflowRunId   String? // when executorKind='workflow', links to WorkflowRun for the full audit trail
  deletedAt       DateTime? // soft delete (cascades from Task soft-delete)
  createdAt       DateTime  @default(now())
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Reverse: workflow runs spawned by this iteration. When the
  // iteration is hard-deleted, the runs cascade away too; soft-delete
  // hides them via the parent filter in app code.
  workflowRuns    WorkflowRun[]

  @@unique([taskId, iterationNumber])
  @@index([taskId, createdAt])
  @@map("task_iterations")
}

model SlackLog {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  messageSent String
  channel     String
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id])

  @@index([projectId, delivered])
  @@map("slack_logs")
}

model ResourceUsage {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  taskId     String?
  cpuSeconds Float    @default(0)
  gpuSeconds Float    @default(0)
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([userId, projectId])
  @@map("resource_usage")
}

model TeamRun {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  teamConfigJson Json
  userMessage    String
  status         String   @default("running")
  plan           Json     @default("{}")
  state          Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("team_runs")
}

model BuildSession {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  buildWith String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, active])
  @@map("build_sessions")
}

// ── Team Workflow Runs ─────────────────────────────────────────────
// Persistência da execução de um workflow fixo (Builder, Review, etc).
// Disparado quando user invoca slash command no chat (ex: /build {task}).
//
// `plan` é o output do Planner (blocks com objective rico).
// `progress` é o estado vivo da run (blocks status, steps por agent,
// rejection counts, artifacts paths, current step). UI poller lê
// daqui pra renderizar o card vivo.
//
// `finalResponse` é a mensagem que o último Reviewer escreveu pra
// devolver ao chat — depois de inserida como ChatMessage, pode ser
// limpa ou mantida pra audit.
model WorkflowRun {
  id            String      @id @default(cuid())
  // Parent — exactly ONE of these is set per row:
  //   sessionId   → chat-driven workflow (cascade-deletes with the chat)
  //   iterationId → task-driven workflow (cascade-deletes with the iteration)
  // App layer enforces "exactly one"; both null or both set is a bug.
  sessionId     String?
  iterationId   String?
  projectId     String
  userId        String
  // Identifica qual workflow fixo: 'builder', 'review', 'test', etc.
  // V1 só tem 'builder'. Adicionamos outros sem mudar schema.
  workflowType  String
  // Mensagem do user (parte depois do slash command).
  userMessage   String
  // Id da chat_message do prompt que disparou esse run. Permite à UI
  // ancorar a WorkflowRunCard inline logo abaixo do user msg correto
  // — em vez de pinar no rodapé do chat. Nullable porque runs antigos
  // (pré-feature) não têm o link.
  triggerMessageId String?
  // 'pending' | 'running' | 'completed' | 'failed' | 'cancelled'
  status        String      @default("pending")
  // Output do Planner: { rationale?, blocks: [{name, objective, estimatedFiles?}] }
  plan          Json?
  // Estado vivo: { blocks: [{ index, name, status, currentStep?, turns: [...] }], currentBlockIndex }
  progress      Json        @default("{}")
  // Resposta que o último Reviewer redigiu pro user. Após postar como
  // ChatMessage, fica aqui pra audit.
  finalResponse String?
  // Quando algo falha, motivo human-readable.
  errorReason   String?
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  // Ownership relations — only one fires per row (sessionId XOR iterationId).
  // Both with cascade so hard-deleting the parent (admin / retention)
  // takes the run with it. Soft-delete is app-level: app code filters
  // workflow runs whose parent has deletedAt set.
  session       ChatSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  iteration     TaskIteration? @relation(fields: [iterationId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([iterationId])
  @@index([projectId, createdAt])
  @@index([userId])
  @@map("workflow_runs")
}

enum TaskStatus {
  pending
  scheduled
  running
  done
  failed
}

enum PermissionMode {
  plan
  edit
  auto
  agent
}

// =========================================================================
// CLOUD MIRROR — shadow-git content-addressed mirror in Postgres.
// See ARCHITECTURE.md "Cloud Mirror" for the full design.
//
// Goal: when local connection dies, user clicks "Continuar na nuvem" and
// gets a bit-perfect reconstruction of the worktree (same branch, same
// commit, uncommitted edits, untracked files, unpushed commits) inside an
// isolated E2B sandbox per worktree. Independent of GitHub remote.
//
// Storage rationale: content-addressed (hash → blob) gives natural dedup
// across branches. A 50 MB working tree shared between 3 branches stores
// roughly 50 MB once, not 150 MB. Per user typical: ~12 MB after gzip +
// encrypt.
// =========================================================================

// Password reset tokens. The actual token bytes leave the server once
// (in the email link) — only the SHA-256 hash is stored, so a DB leak
// can't be used to reset arbitrary user passwords. One-shot use: the
// `usedAt` stamp blocks a second redeem even if the email link is
// resent. Expiry default 1h.
model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  ipAddress  String?  // best-effort, for abuse audit

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Per-user data encryption key, wrapped by the KMS master key.
// `wrappedKey` is the user's DEK encrypted by the master; the master
// never leaves KMS. Revoking (revokedAt != null) renders every blob
// for this user permanently unreadable — that is our right-to-erasure
// hook. Hard-delete of the actual GitObject / UnpushedCommit rows runs
// as a separate background job after a grace period.
model UserEncryptionKey {
  userId      String    @id
  wrappedKey  Bytes
  kmsKeyId    String
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_encryption_keys")
}

// Content-addressed blob. (userId, hash) is the PK so the same hash can
// coexist across users without cross-user dedup (privacy: cross-user
// dedup would let us infer that user A and user B have an identical
// file). `content` is gzipped, then encrypted with the user's DEK.
// `refCount` is maintained in application code as WorktreeFileEntry
// rows are created / deleted; GC sweeps rows where refCount = 0 after
// a 24h cool-down (handles racey upload-then-delete).
model GitObject {
  hash        String
  userId      String
  content     Bytes
  sizeBytes   Int
  refCount    Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, hash])
  @@index([userId, refCount])
  @@map("git_objects")
}

// One row per worktree. Pointer to the branch / commit the worktree
// currently reflects. `treeRootHash` is nullable because we set it
// only after the first successful sync completes — until then there
// is no canonical tree state.
model WorktreeMirror {
  worktreeId        String   @id
  currentBranch     String
  currentCommitSha  String
  treeRootHash      String?
  lastSyncAt        DateTime @default(now())
  totalSizeBytes    BigInt   @default(0)
  fileCount         Int      @default(0)
  // Tracks whether the daemon has finished the initial walk after
  // worktree creation. Cloud activation refuses to proceed if not
  // 'ready' — better a friendly "preparing mirror, please wait"
  // than booting a sandbox with a half-populated tree.
  status            String   @default("warming")

  worktree          Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@map("worktree_mirrors")
}

// Path → hash mapping inside a worktree. One row per file currently
// present. Deleted files are removed from this table (not soft-deleted
// here — the `WorktreeMirror.lastSyncAt` is the deletion checkpoint).
// `hash` references GitObject(userId, hash) in app code, not via FK,
// because we need to fetch userId from the worktree → project → user
// chain (adding userId here would denormalize and require sync on
// owner change).
model WorktreeFileEntry {
  id          String   @id @default(cuid())
  worktreeId  String
  path        String
  hash        String
  mode        Int
  status      String   // 'tracked' | 'untracked' | 'modified'
  syncedAt    DateTime @default(now())

  worktree    Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@unique([worktreeId, path])
  @@index([worktreeId])
  @@index([hash])
  @@map("worktree_file_entries")
}

// One row per cloud sandbox spun up for a worktree. The lifecycle:
//   provisioning → materializing → ready → destroyed (or failed)
// The `token` is the bearer the sandbox uses when calling our APIs
// (materialize, blob, claude event POSTs). It's distinct from the
// CompanionToken so we can revoke/audit independently and so the auth
// helper knows to flip routing into "cloud" mode for this worktree.
model SandboxSession {
  id            String   @id @default(cuid())
  worktreeId    String
  userId        String
  e2bSandboxId  String?
  token         String   @unique
  status        String   // 'provisioning' | 'materializing' | 'ready' | 'destroyed' | 'failed'
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  destroyedAt   DateTime?
  errorReason   String?

  worktree      Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([worktreeId, status])
  @@index([userId])
  @@map("sandbox_sessions")
}

// Local-only commits the user has made but not pushed to their remote.
// Stored as `git format-patch` output so cloud reconstruction can
// replay them with `git am`. `orderIndex` preserves chronological
// order. When the user pushes, the daemon removes corresponding rows.
model UnpushedCommit {
  id            String   @id @default(cuid())
  worktreeId    String
  commitSha     String
  parentSha     String
  message       String
  authorName    String
  authorEmail   String
  authorDate    DateTime
  patchContent  Bytes
  orderIndex    Int
  createdAt     DateTime @default(now())

  worktree      Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@unique([worktreeId, commitSha])
  @@index([worktreeId, orderIndex])
  @@map("unpushed_commits")
}
